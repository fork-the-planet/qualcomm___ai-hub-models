+    def _peak_2d(self, scores, ft_size=48):
+        """Locate the per-channel spatial peak without ever flattening H*W.
+
+        A plain ``argmax`` over the flattened ``ft_size*ft_size`` grid returns
+        indices up to 2303 for a 48x48 map.  fp16 (used by the NPU) can only
+        represent integers exactly up to 2048, so reconstructing ``(y, x)`` from
+        such an index -- and gathering at it -- silently corrupts every peak in the
+        bottom rows.  Instead we run a separable 2-D argmax: the global peak's row
+        is the argmax of the per-row maxima and its column is the argmax of the
+        per-column maxima.  Both coordinates stay in ``[0, ft_size-1]`` (<= 47),
+        which is exact in fp16.  One-hot row/col selectors are returned so values
+        can be read with a multiply-reduce instead of an (unsupported) gather.
+
+        scores: [H, W, C]
+        returns y, x: [C] float coords; oh_y: [C, H], oh_x: [C, W] one-hot.
+        """
+        s = scores.permute(2, 0, 1)                       # [C, H, W]
+        y = s.max(dim=2).values.argmax(dim=1).float()     # [C]
+        x = s.max(dim=1).values.argmax(dim=1).float()     # [C]
+        axis = self.axis_index.reshape(1, ft_size)
+        oh_y = (axis == y.reshape(-1, 1)).to(scores.dtype)  # [C, H]
+        oh_x = (axis == x.reshape(-1, 1)).to(scores.dtype)  # [C, W]
+        return y, x, oh_y, oh_x
